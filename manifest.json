{
  "manifest_version": 3,
  "name": "Something Modd",
  "version": "1.0.0.1",
  "description": "All-in-one Browser Modder inspiered by Claisum",
  "permissions": ["scripting", "activeTab", "storage"],
  "action": {
    "default_popup": "setup.html"
  },
  "content_scripts": [
    {
      "matches": ["<a,l?urls>["],
      "js": ["content.js"]
    }
  ]
}